# ===== GOOGLE AUTH (optional — app stays open/local without it) =====
# Set these on the hosted deployment (e.g. HF Space secrets) to lock the app
# to invited Google accounts. See AUTH-SETUP.md for the click-by-click guide.
# GOOGLE_CLIENT_ID=1234567890-abc.apps.googleusercontent.com
# SESSION_SECRET=some-long-random-string
# ALLOWED_EMAILS=you@gmail.com,friend@gmail.com
# AI_DAILY_LIMIT=20

# ===== LLM (ALL OPTIONAL — the app is fully functional without any key) =====
# Provider selection: auto (default) picks whichever key is present.
# LLM_PROVIDER=auto            # auto | anthropic | openai | gemini | ollama | none

# Paid keys — paste one and the AI narrative + palm photo reading go live:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# 100% free local option (see docker-compose.yml ollama service):
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1
